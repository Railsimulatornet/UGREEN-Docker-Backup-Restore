# UGREEN Docker Backup & Restore - example configuration
# Copyright Roman Glos 2026

# de = Deutsch, en = English
LANGUAGE=de
HOST_LABEL="UGREEN NAS"

# Base paths
SOURCE_DIR=auto
BACKUP_DIR=/volume2/DockerBackup
TEMP_DIR=
LOG_DIR=
KEEP_BACKUPS=5
COMPRESS_BACKUP=true

# Backup behaviour
STOP_CONTAINERS=true
STOP_TIMEOUT=20

# Project/container selection
BACKUP_ALL_PROJECTS=true
INCLUDE_PROJECTS=""
EXCLUDE_PROJECTS=""
EXCLUDE_CONTAINERS=""
BACKUP_STANDALONE_CONTAINERS=true
BACKUP_EXCLUDE_PATHS_FILE=backup-exclude-paths.txt

# Backup content
BACKUP_IMAGES=false
BACKUP_NAMED_VOLUMES=false
BACKUP_EXTERNAL_BINDS=false

# Optional remote backup via SSH/SCP
ENABLE_REMOTE_BACKUP=false
REMOTE_HOST=
REMOTE_USER=
REMOTE_PORT=22
REMOTE_PATH=
REMOTE_KEEP_BACKUPS=5

# E-mail notification
SEND_MAIL=false
MAIL_NOTIFY_ON=all
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
MAIL_FROM=
MAIL_TO=
MAIL_SUBJECT_PREFIX="[UGREEN Docker Backup]"

# Optional shutdown after successful backup
SHUTDOWN_AFTER_SUCCESS=false

# Restore selection
RESTORE_ARCHIVE=
DRY_RUN=true
RESTORE_ALL_PROJECTS=false
RESTORE_PROJECTS=""
RESTORE_OVERWRITE_EXISTING=false
RESTORE_IMAGES=false
RESTORE_NAMED_VOLUMES=false
RESTORE_EXTERNAL_BINDS=false
RESTORE_STANDALONE_CONTAINERS=true

# Restore path remapping
ENABLE_PATH_REMAP=true
PATH_REMAP_FILE=path-remap.tsv

# UGOS Docker App integration
UPDATE_UGOS_DOCKER_DB=true
REFRESH_UGOS_DOCKER_APP=true
KEEP_UGOS_DB_BACKUPS=10
